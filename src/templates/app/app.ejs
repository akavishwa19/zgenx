<%_ if (type === 'esm') { _%>
import express from 'express';
<%_ if (language === 'typescript') { _%>
import type { Request, Response } from 'express';
import type { Server } from 'http';
<%_ } _%>
import 'dotenv/config';
<%_ if (logger === 'yes') { _%>
import logger from './utils/logger';
<%_ } _%>
import { connectToDb } from './db/client';
import router from './routes';
<%_ } else { _%>
const express = require('express');
require('dotenv/config');
<%_ if (logger === 'yes') { _%>
const logger = require('./utils/logger');
<%_ } _%>
const { connectToDb } = require('./db/client');
const router = require('./routes');
<%_ } _%>

const app = express();

app.use(express.json());

const port = process.env.PORT;
let server<%_ if (language === 'typescript') { _%>: Server | undefined<%_ } _%>;
<%_
const logInfo = logger === 'yes' ? 'logger.info' : 'console.log';
const logError = logger === 'yes' ? 'logger.error' : 'console.error';
_%>

function setupRoutes() {
  app.use('/api/v1', router);
}

const startServer = async ()<%_ if (language === 'typescript') { _%>: Promise<void><%_ } _%> => {
  setupRoutes();
  await connectToDb();
  server = app.listen(port, () => {
    <%= logInfo %>('app listening on http://localhost:' + port);
  });
};

function stopServer(signal<%_ if (language === 'typescript') { _%>: string, code: number<%_ } _%>) {
  <%= logInfo %>(`recieved ${signal} , stopping server gracefully`);
  if (server) {
    server.close(() => {
      <%= logInfo %>('server closed succesfully');
      process.exit(code);
    });
  } else {
    process.exit(code);
  }
}

process.once('SIGINT', () => {
  stopServer('SIGINT', 0);
});

process.once('SIGTERM', () => {
  stopServer('SIGTERM', 0);
});

process.on('uncaughtException', (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) => {
  <%= logError %>({ error }, 'uncaught exception');
  stopServer('UNCAUGHT_EXCEPTION', 1);
});

process.on('unhandledRejection', (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) => {
  <%= logError %>({ error }, 'unhandled rejection');
  stopServer('UNHANDLED_REJECTION', 1);
});

async function bootstrapApplication()<%_ if (language === 'typescript') { _%>: Promise<void><%_ } _%> {
  try {
    await startServer();
  } catch (error) {
    if (error instanceof Error) {
      <%= logError %>(
        { message: error.message, stack: error.stack },
        'failed to bootstrap application'
      );
    } else {
      <%= logError %>({ error }, 'failed to bootstrap application');
    }
    stopServer('STARTUP_ERROR', 1);
  }
}

if (process.env.NODE_ENV !== 'test') {
  bootstrapApplication();
}

<%_ if (type === 'esm') { _%>
export { bootstrapApplication };
<%_ } else { _%>
module.exports = { bootstrapApplication };
<%_ } _%>