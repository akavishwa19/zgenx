<%_
const apiName = api.charAt(0).toUpperCase() + api.slice(1);
_%>
<%_ if (type === 'esm') { _%>
import { <%= apiName %>Service } from '../services/<%= api %>';
<%_ if (logger === 'yes') { _%>
import logger from '../utils/logger';
<%_ } _%>
<%_ if (language === 'typescript') { _%>
import { Request, Response } from 'express';
<%_ } _%>
<%_ } else { _%>
const { <%= apiName %>Service } = require('../services/<%= api %>');
<%_ if (logger === 'yes') { _%>
const logger = require('../utils/logger');
<%_ } _%>
<%_ } _%>
<%_
const logError = logger === 'yes' ? 'logger.error' : 'console.error';
const logInfo = logger === 'yes' ? 'logger.info' : 'console.log';
const idExtract = language === 'typescript'
  ? 'const id = req.params.id as string;'
  : 'const { id } = req.params;';
_%>

const create = async (req<%_ if (language === 'typescript') { _%>: Request<%_ } _%>, res<%_ if (language === 'typescript') { _%>: Response<%_ } _%>) => {
  try {
    const id = await <%= apiName %>Service.create(req.body);
    <%= logInfo %>(`Created <%= api %> with id: ${id}`);
    return res.status(201).json({ success: true, data: { id } });
  } catch (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) {
    <%= logError %>({ error }, 'Failed to create <%= api %>');
    return res.status(500).json({ success: false, message: 'Failed to create <%= api %>' });
  }
};

const update = async (req<%_ if (language === 'typescript') { _%>: Request<%_ } _%>, res<%_ if (language === 'typescript') { _%>: Response<%_ } _%>) => {
  try {
    <%= idExtract %>

    if (!id) {
      return res.status(400).json({ success: false, message: 'id is required' });
    }

    const updatedId = await <%= apiName %>Service.update(id, req.body);
    <%= logInfo %>(`Updated <%= api %> with id: ${updatedId}`);
    return res.status(200).json({ success: true, data: { id: updatedId } });
  } catch (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) {
    <%= logError %>({ error }, 'Failed to update <%= api %>');
    return res.status(500).json({ success: false, message: 'Failed to update <%= api %>' });
  }
};

const get = async (req<%_ if (language === 'typescript') { _%>: Request<%_ } _%>, res<%_ if (language === 'typescript') { _%>: Response<%_ } _%>) => {
  try {
    <%= idExtract %>

    if (!id) {
      return res.status(400).json({ success: false, message: 'id is required' });
    }

    const data = await <%= apiName %>Service.get(id);
    <%= logInfo %>(`Fetched <%= api %> with id: ${id}`);
    return res.status(200).json({ success: true, data });
  } catch (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) {
    <%= logError %>({ error }, 'Failed to fetch <%= api %>');
    return res.status(500).json({ success: false, message: 'Failed to fetch <%= api %>' });
  }
};

const list = async (_req<%_ if (language === 'typescript') { _%>: Request<%_ } _%>, res<%_ if (language === 'typescript') { _%>: Response<%_ } _%>) => {
  try {
    const data = await <%= apiName %>Service.list();
    <%= logInfo %>(`Fetched <%= api %> list`);
    return res.status(200).json({ success: true, data });
  } catch (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) {
    <%= logError %>({ error }, 'Failed to list <%= api %>');
    return res.status(500).json({ success: false, message: 'Failed to list <%= api %>' });
  }
};

const remove = async (req<%_ if (language === 'typescript') { _%>: Request<%_ } _%>, res<%_ if (language === 'typescript') { _%>: Response<%_ } _%>) => {
  try {
    <%= idExtract %>

    if (!id) {
      return res.status(400).json({ success: false, message: 'id is required' });
    }

    await <%= apiName %>Service.delete(id);
    <%= logInfo %>(`Deleted <%= api %> with id: ${id}`);
    return res.status(200).json({ success: true, data: { id } });
  } catch (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) {
    <%= logError %>({ error }, 'Failed to delete <%= api %>');
    return res.status(500).json({ success: false, message: 'Failed to delete <%= api %>' });
  }
};

<%_ if (type === 'esm') { _%>
export { create, update, get, list, remove };
<%_ } else { _%>
module.exports = { create, update, get, list, remove };
<%_ } _%>