{
  "name": "aka-node-gen",
  "version": "0.0.0",
  "description": "node utility to build APIs at pace",
  "keywords": [
    "express",
    "nodejs",
    "typescript",
    "jest",
    "generator",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/akavishwa19/aka-node-gen"
  },
  "bugs": {
    "url": "https://github.com/akavishwa19/aka-node-gen/issues"
  },
  "author": "Akash Vishwakarma <akash19102001@gmail.com> (https://www.akashvishwakarma.com)",
  "license": "MIT",
  "type": "commonjs",
  "main": "src/index.ts",
  "scripts": {
    "format": "prettier --log-level=silent --write .",
    "format:check": "prettier --log-level=silent --check .",
    "clean": "rimraf dist",
    "build": "tsc --project tsconfig.json",
    "pretest": "npm run clean && npm run build",
    "test": "jest",
    "test:coverage": "jest --coverage --runInBand",
    "prelint": "npm run clean && npm run build",
    "lint:fix": "eslint --fix src tests",
    "lint": "eslint src tests",
    "dev": "ts-node src/index.ts",
    "start:dev": "node dist/index.js",
    "start": "npm run clean && npm run build && npm run start:dev",
    "preversion": "npm run lint && npm run test",
    "version": "echo $npm_package_version",
    "prepare": "husky"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.2.4",
    "inquirer": "^13.4.1",
    "ora": "^9.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/inquirer": "^9.0.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "engines": {
    "node": ">=24"
  }
}
